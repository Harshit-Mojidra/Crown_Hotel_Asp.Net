@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="modal fade" id="resetModal">
    <div class="modal-dialog">
        <div class="modal-content p-3">

            <h5>Reset Password</h5>

            <form method="post" action="/Account/ResetPassword">
                <input type="hidden" name="token" value="@ViewBag.Token" />

                <input type="password" name="newPassword" class="form-control mt-3" placeholder="New Password" required />
                <input type="password" name="confirmPassword" class="form-control mt-2" placeholder="Confirm Password" required />

                <button class="btn btn-dark mt-3 w-100">Update Password</button>
            </form>

            <p class="text-success mt-2">@ViewBag.Message</p>

        </div>
    </div>
</div>

<script>
    var myModal = new bootstrap.Modal(document.getElementById('resetModal'));
    myModal.show();
</script>