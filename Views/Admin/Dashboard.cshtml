@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Dashboard";
}

<div class="container-fluid">

    <h2 class="mb-4">DASHBOARD</h2>

    <!-- AUTO REFRESH -->
    <meta http-equiv="refresh" content="5">

    <!-- TOP CARDS -->
    <div class="row text-center mb-4">

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-success">New Bookings (Paid)</h6>
                <h2>@(ViewBag.PaidBookings ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-danger">Cancelled Bookings</h6>
                <h2>@(ViewBag.CancelledBookings ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-primary">Total Users</h6>
                <h2>@(ViewBag.TotalUsers ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-info">Active Users</h6>
                <h2>@(ViewBag.ActiveUsers ?? 0)</h2>
            </div>
        </div>

    </div>

    <!-- BOOKING ANALYTICS -->
    <h4 class="mb-3">Booking Analytics</h4>

    <div class="row text-center mb-4">

        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h6 class="text-primary">Total Bookings</h6>
                <h2>@(ViewBag.TotalBookings ?? 0)</h2>
                <p>₹@(ViewBag.TotalAmount ?? 0)</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h6 class="text-success">Active (Paid)</h6>
                <h2>@(ViewBag.PaidBookings ?? 0)</h2>
                <p>₹@(ViewBag.PaidAmount ?? 0)</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h6 class="text-danger">Cancelled</h6>
                <h2>@(ViewBag.CancelledBookings ?? 0)</h2>
                <p>₹@(ViewBag.CancelledAmount ?? 0)</p>
            </div>
        </div>

    </div>

    <!-- USERS -->
    <h4 class="mb-3">Users</h4>

    <div class="row text-center">

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6>Total</h6>
                <h2>@(ViewBag.TotalUsers ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-success">Active</h6>
                <h2>@(ViewBag.ActiveUsers ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-warning">Inactive</h6>
                <h2>@(ViewBag.InactiveUsers ?? 0)</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6 class="text-danger">Unverified</h6>
                <h2>@(ViewBag.UnverifiedUsers ?? 0)</h2>
            </div>
        </div>

    </div>

</div>