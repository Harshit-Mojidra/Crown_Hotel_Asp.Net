@model List<hrbs_project.Models.Feature>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Features & Facilities";

    var facilities = ViewBag.Facilities as List<hrbs_project.Models.Facility>;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2 class="mb-4">FEATURES & FACILITIES</h2>

<div class="row">

    <!-- ================= FEATURES ================= -->
    <div class="col-md-5">
        <div class="card p-3 shadow-sm">

            <div class="d-flex justify-content-between mb-3">
                <h4>Features</h4>
                <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#featureModal">
                    + Add
                </button>
            </div>

            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.name</td>
                                <td>
                                    <button class="btn btn-danger btn-sm"
                                            onclick="deleteFeature(@item.id)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">No Features Found</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

    <!-- ================= FACILITIES ================= -->
    <div class="col-md-7">
        <div class="card p-3 shadow-sm">

            <div class="d-flex justify-content-between mb-3">
                <h4>Facilities</h4>
                <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#facilityModal">
                    + Add
                </button>
            </div>

            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Icon</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (facilities != null && facilities.Any())
                    {
                        int i = 1;
                        foreach (var item in facilities)
                        {
                            <tr>
                                <td>@i</td>
                                <td>
                                    <img src="@item.IconPath" width="50" />
                                </td>
                                <td>@item.Name</td>
                                <td>@item.Description</td>
                                <td>
                                    <button class="btn btn-danger btn-sm"
                                            onclick="deleteFacility(@item.Id)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">No Facilities Found</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>

<!-- ================= FEATURE MODAL ================= -->
<div class="modal fade" id="featureModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Add Feature</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="text" id="featureName" class="form-control" placeholder="Enter feature name" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" onclick="addFeature()">Submit</button>
            </div>

        </div>
    </div>
</div>

<!-- ================= FACILITY MODAL ================= -->
<div class="modal fade" id="facilityModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Add Facility</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="text" id="facilityName" class="form-control mb-2" placeholder="Name" />

                <input type="file" id="facilityIcon" class="form-control mb-2" />

                <textarea id="facilityDesc" class="form-control" placeholder="Description"></textarea>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" onclick="addFacility()">Submit</button>
            </div>

        </div>
    </div>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // ADD FEATURE
    function addFeature() {

        var name = $("#featureName").val();

        if (name == "") {
            alert("Enter feature name");
            return;
        }

        $.post('/Feature/AddFeature', { Name: name }, function () {
            location.reload();
        });
    }

    // DELETE FEATURE
    function deleteFeature(id) {

        if (confirm("Delete this feature?")) {
            $.post('/Feature/DeleteFeature', { id: id }, function () {
                location.reload();
            });
        }
    }

    // ADD FACILITY
    function addFacility() {

        var formData = new FormData();

        formData.append("Name", $("#facilityName").val());
        formData.append("Description", $("#facilityDesc").val());
        formData.append("IconFile", $("#facilityIcon")[0].files[0]);

        $.ajax({
            url: '/Facility/AddFacility',
            type: 'POST',
            data: formData,
            contentType: false,
            processData: false,
            success: function () {
                location.reload();
            }
        });
    }

    // DELETE FACILITY
    function deleteFacility(id) {

        if (confirm("Delete this facility?")) {
            $.post('/Facility/DeleteFacility', { id: id }, function () {
                location.reload();
            });
        }
    }
</script>