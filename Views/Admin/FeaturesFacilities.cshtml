@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var features = ViewBag.Features;
    var facilities = ViewBag.Facilities;
}

<div class="container mt-3">

    <h3 class="mb-4">FEATURES & FACILITIES</h3>

    <!-- ================= FEATURES ================= -->
    <div class="card p-3 mb-4 shadow-sm">
        <div class="d-flex justify-content-between align-items-center">
            <h5>Features</h5>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addFeature">
                + Add
            </button>
        </div>

        <table class="table mt-3">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th style="width:120px;">Action</th>
                </tr>
            </thead>

            <tbody>
                @{
                    int i = 1;
                    if (features != null)
                    {
                        foreach (var f in features)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@f.Name</td>
                                <td>
                                    <a href="/Admin/DeleteFeature/@f.Id"
                                       onclick="return confirm('Delete this feature?')"
                                       class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- ================= FACILITIES ================= -->
    <div class="card p-3 shadow-sm">
        <div class="d-flex justify-content-between align-items-center">
            <h5>Facilities</h5>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addFacility">
                + Add
            </button>
        </div>

        <table class="table mt-3">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Icon</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th style="width:120px;">Action</th>
                </tr>
            </thead>

            <tbody>
                @{
                    int j = 1;
                    if (facilities != null)
                    {
                        foreach (var f in facilities)
                        {
                            <tr>
                                <td>@j</td>
                                <td>
                                    <img src="@f.Icon" width="40" height="40" style="object-fit:contain;" />
                                </td>
                                <td>@f.Name</td>
                                <td>@f.Description</td>
                                <td>
                                    <a href="/Admin/DeleteFacility/@f.Id"
                                       onclick="return confirm('Delete this facility?')"
                                       class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                            j++;
                        }
                    }
                }
            </tbody>
        </table>
    </div>

</div>


<!-- ================= ADD FEATURE MODAL ================= -->
<div class="modal fade" id="addFeature" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" action="/Admin/AddFeature" class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Feature</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" required />
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-success">
                    Submit
                </button>
            </div>

        </form>
    </div>
</div>


<!-- ================= ADD FACILITY MODAL ================= -->
<div class="modal fade" id="addFacility" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" action="/Admin/AddFacility" class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Facility</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <label class="form-label">Icon (Image Path)</label>
                <input type="text" name="icon" class="form-control mb-2" placeholder="/images/wifi.png" required />

                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control mb-2" required />

                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3" required></textarea>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-success">
                    Submit
                </button>
            </div>

        </form>
    </div>
</div>