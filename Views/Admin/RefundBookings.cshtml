@using hrbs_project.Models
@model List<Booking>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2 class="mb-4">REFUND BOOKINGS</h2>

    <div class="card p-3 shadow-sm">

        <div class="d-flex justify-content-end mb-3">
            <input type="text" class="form-control w-25" placeholder="Type to search..." />
        </div>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>User Details</th>
                    <th>Room Details</th>
                    <th>Refund Amount</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center">No Data Found</td>
                    </tr>
                }
                else
                {
                    int i = 1;

                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@i</td>

                            <td>
                                <span class="badge bg-primary">
                                    Order ID: @item.order_id
                                </span><br />

                                <b>Name:</b> @item.user_name <br />
                                <b>Phone:</b> @item.phone
                            </td>

                            <td>
                                <b>Room:</b> @item.room_name <br />
                                <b>Check-in:</b> @item.check_in.ToString("dd-MM-yyyy") <br />
                                <b>Check-out:</b> @item.check_out.ToString("dd-MM-yyyy") <br />
                                <b>Date:</b> @item.booking_date.ToString("dd-MM-yyyy")
                            </td>

                            <td>
                                ₹@item.paid_amount
                            </td>

                            <td>
                                @if (item.refund_status != "Refunded")
                                {
                                    <form asp-action="CompleteRefund" method="post">
                                        <input type="hidden" name="orderId" value="@item.Id" />
                                        <button class="btn btn-warning">Complete Refund</button>
                                    </form>
                                    <form method="post" asp-action="ProcessRefund">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            Refund
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-success">Refunded</span>
                                }
                            </td>
                        </tr>

                        i++;
                    }
                }
            </tbody>
        </table>

    </div>

</div>