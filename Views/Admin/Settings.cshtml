@model Settings

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">

    <h3 class="mb-4">SETTINGS</h3>

    <!-- GENERAL SETTINGS -->
    <div class="card p-3 mb-4 shadow-sm">
        <div class="d-flex justify-content-between">
            <h5>General Settings</h5>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#generalSettingsModal">
                Edit
            </button>
        </div>

        <p><strong>Site Title:Crown Hotel</strong> @Model.SiteTitle</p>
        <p><strong>About us:</strong> @Model.About</p>
    </div>

    <!-- SHUTDOWN -->
    <div class="card p-3 mb-4 shadow-sm">
        <div class="d-flex justify-content-between">
            <h5>Shutdown Website</h5>

            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox"
                       @(Model.IsShutdown ? "checked" : "") />
            </div>
        </div>

        <p>No customers will be allowed to book hotel room when shutdown mode is ON.</p>
    </div>

    <!-- CONTACT SETTINGS -->
    <div class="card p-3 mb-4 shadow-sm">
        <div class="d-flex justify-content-between">
            <h5>Contacts Settings</h5>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#contactSettingsModal">
                Edit
            </button>
        </div>

        <div class="row">
            <div class="col-md-6">
                <p><strong>Address:Rajkot</strong> @Model.Address</p>
                <p><strong>Phone:9999999999</strong> @Model.Phone1</p>
                <p><strong>Email:crownhotel@gmail.com</strong> @Model.Email</p>
            </div>

            <div class="col-md-6">
                <p><strong>Facebook:</strong> @Model.Facebook</p>

                <p class="mt-3"><strong>Google Map</strong></p>

                <iframe src="@Model.Iframe"
                        style="width:100%; height:200px; border:0;"
                        loading="lazy"
                        allowfullscreen>
                </iframe>
            </div>
        </div>
    </div>

    <!-- TEAM SECTION -->
    <div class="card p-3 shadow-sm">
        <div class="d-flex justify-content-between mb-3">
            <h5>Management Team</h5>

            <!-- ADD BUTTON -->
            <button class="btn btn-success btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#addTeamModal">
                Add
            </button>
        </div>

        <div class="row">
            @if (Model.TeamMembers != null && Model.TeamMembers.Any())
            {
                foreach (var member in Model.TeamMembers)
                {
                    <div class="col-md-2 text-center mb-3">
                        <div class="card">
                            <img src="@member.ImagePath" class="card-img-top img-fluid" />

                            <div class="card-body p-2">

                                <!-- DELETE BUTTON -->
                                <form asp-action="DeleteTeamMember" method="post">
                                    <input type="hidden" name="id" value="@member.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm mb-2">
                                        Delete
                                    </button>
                                </form>

                                <p>@member.Name</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No team members added yet.</p>
            }
        </div>
    </div>

</div>

<!-- ===================== MODALS ===================== -->
<!-- ADD TEAM MEMBER MODAL -->
<div class="modal fade" id="addTeamModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="AddTeamMember" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Add Team Member</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label>Name</label>
                        <input type="text" name="Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Picture</label>
                        <input type="file" name="ImageFile" class="form-control" required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-success">
                        Submit
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- GENERAL SETTINGS MODAL -->
<div class="modal fade" id="generalSettingsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateGeneralSettings" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">General Settings</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label>Site Title</label>
                        <input type="text" name="SiteTitle" class="form-control" value="@Model.SiteTitle" />
                    </div>

                    <div class="mb-3">
                        <label>About</label>
                        <textarea name="About" class="form-control">@Model.About</textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- CONTACT SETTINGS MODAL -->
<div class="modal fade" id="contactSettingsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="UpdateContactSettings" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Contact Settings</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="row">

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label>Address</label>
                                <input type="text" name="Address" class="form-control" value="@Model.Address" />
                            </div>

                            <div class="mb-3">
                                <label>Phone</label>
                                <input type="text" name="Phone1" class="form-control" value="@Model.Phone1" />
                            </div>

                            <div class="mb-3">
                                <label>Email</label>
                                <input type="email" name="Email" class="form-control" value="@Model.Email" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label>Facebook</label>
                                <input type="text" name="Facebook" class="form-control" value="@Model.Facebook" />
                            </div>

                            <div class="mb-3">
                                <label>Google Map Iframe</label>
                                <input type="text" name="Iframe" class="form-control" value="@Model.Iframe" />
                            </div>
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>