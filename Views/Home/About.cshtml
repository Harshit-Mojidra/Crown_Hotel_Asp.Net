@{
    ViewBag.Title = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <!-- TITLE -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">ABOUT US</h2>
        <p class="text-muted">
            We aim to simplify the booking process by offering a secure, reliable,
            and convenient solution for both users and hotel management.
            Our Hotel Room Booking System provides a fast, user-friendly platform.
        </p>
    </div>

    <!-- ABOUT SECTION -->
    <div class="row align-items-center mb-5">

        <div class="col-md-6">
            <h4>Manage by V8 Group</h4>
            <p>
                V8 Group is the proficient and tech-savvy manager of the Hotel
                Management System, ensuring seamless operations and top-notch
                guest experiences. With a sharp eye for detail, V8 Group oversees
                reservations, staff coordination, billing, and inventory management.
            </p>
        </div>

        <div class="col-md-6 text-center">
            <img src="~/images/about/hacker.jpg" class="img-fluid rounded" alt="About Image" />
        </div>

    </div>

    <!-- STATS -->
    <div class="row text-center mb-5">

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>100+ ROOMS</h5>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>200+ CUSTOMERS</h5>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>150+ REVIEWS</h5>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>200+ STAFFS</h5>
            </div>
        </div>

    </div>

    <!-- TEAM -->
    <div class="text-center mb-4">
        <h3>MANAGEMENT TEAM</h3>
    </div>

    <div class="row">

        <div class="col-md-4 text-center mb-4">
            <img src="~/images/about/ING_22216.jpg" class="img-fluid rounded shadow-sm" />
            <p class="mt-2">Team Member 1</p>
        </div>

        <div class="col-md-4 text-center mb-4">
            <img src="~/images/about/ING_24429.jpg" class="img-fluid rounded shadow-sm" />
            <p class="mt-2">Team Member 2</p>
        </div>

        <div class="col-md-4 text-center mb-4">
            <img src="~/images/about/ING_36028.jpg" class="img-fluid rounded shadow-sm" />
            <p class="mt-2">Team Member 3</p>
        </div>

    </div>

</div>