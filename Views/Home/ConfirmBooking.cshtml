@model hrbs_project.Models.BookingViewModel

@{
    ViewBag.Title = "Confirm Booking";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var checkInDate = Model.CheckIn?.ToString("yyyy-MM-dd") ?? "";
    var checkOutDate = Model.CheckOut?.ToString("yyyy-MM-dd") ?? "";
}

<div class="container mt-5">
    <h2 class="mb-3">CONFIRM BOOKING</h2>

    <div class="row mt-4">

        <!-- LEFT -->
        <div class="col-md-7">
            <div class="card shadow-sm p-3">

                <img src="/images/rooms/@Model.Image"
                     class="img-fluid rounded mb-3"
                     style="height:350px; object-fit:cover;" />

                <h5>@Model.RoomName</h5>
                <p>₹@Model.Price per night</p>

            </div>
        </div>

        <!-- RIGHT -->
        <div class="col-md-5">
            <div class="card shadow-sm p-4">

                <h5 class="mb-3">BOOKING DETAILS</h5>

                <form id="bookingForm">

                    <input type="hidden" id="roomId" value="@Model.RoomId" />

                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Name</label>
                            <input id="name" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-2">
                            <label>Phone Number</label>
                            <input id="phone" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label>Address</label>
                        <textarea id="address" class="form-control"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label>Check-in</label>
                            <!-- ✅ FIXED -->
                            <input id="checkin" type="date" class="form-control" value="@checkInDate" />
                        </div>

                        <div class="col-md-6 mb-2">
                            <label>Check-out</label>
                            <!-- ✅ FIXED -->
                            <input id="checkout" type="date" class="form-control" value="@checkOutDate" />
                        </div>
                    </div>

                    <!-- TOTAL -->
                    <h5 class="mt-3">
                        Total Price: ₹<span id="totalPrice">@Model.TotalPrice</span>
                    </h5>

                    <p id="errorMsg" style="color:red;"></p>

                    <button type="button" onclick="payNow()"
                            class="btn w-100 mt-2"
                            style="background:#5bb7a8; color:white;">
                        Pay Now
                    </button>

                </form>

            </div>
        </div>

    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    function payNow() {

        var name = document.getElementById("name").value;
        var phone = document.getElementById("phone").value;
        var checkin = document.getElementById("checkin").value;
        var checkout = document.getElementById("checkout").value;
        var roomId = document.getElementById("roomId").value;

        if (!name || !phone || !checkin || !checkout) {
            document.getElementById("errorMsg").innerText = "Please fill all fields!";
            return;
        }

        fetch('/Home/CreateOrder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `roomId=${roomId}&checkin=${checkin}&checkout=${checkout}`
        })
        .then(res => res.json())
        .then(data => {

            if (data.error) {
                document.getElementById("errorMsg").innerText = data.error;
                return;
            }

            var options = {
                "key": "@ViewBag.RazorpayKey",   // ✅ FIXED
                "amount": data.amount * 100,
                "currency": "INR",
                "order_id": data.id,
                "name": "CROWN PALACE",
                "description": "Room Booking",

                "handler": function (response) {

                    var url = "/Home/PaymentSuccess?" +
                        "razorpay_payment_id=" + response.razorpay_payment_id +
                        "&razorpay_order_id=" + response.razorpay_order_id +
                        "&razorpay_signature=" + response.razorpay_signature +
                        "&roomId=" + roomId +
                        "&name=" + encodeURIComponent(name) +
                        "&phone=" + encodeURIComponent(phone) +
                        "&checkin=" + checkin +
                        "&checkout=" + checkout;

                    window.location.href = url;
                }
            };

            var rzp = new Razorpay(options);
            rzp.open();
        })
        .catch(err => {
            console.log(err);
            document.getElementById("errorMsg").innerText = "Payment failed to start!";
        });
    }
</script>