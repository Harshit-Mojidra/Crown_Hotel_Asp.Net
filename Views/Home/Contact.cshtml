@{
    ViewBag.Title = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <!-- TITLE -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">CONTACT US</h2>
        <p class="text-muted">
            Need help with your booking? Reach out to our team anytime.
            Have questions? Contact us and we’ll respond as quickly as possible.
        </p>
    </div>

    <div class="row">

        <!-- LEFT SIDE (MAP + INFO) -->
        <div class="col-md-6 mb-4">
            <div class="card p-3 shadow-sm">

                <!-- GOOGLE MAP -->
                <iframe src="https://www.google.com/maps?q=Rajkot,Gujarat&output=embed"
                        width="100%"
                        height="250"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy">
                </iframe>

                <!-- ADDRESS -->
                <div class="mt-3">
                    <h5>Address</h5>
                    <p>📍 Rajkot, Gujarat, India</p>

                    <h5>Call us</h5>
                    <p>📞 +918952099520</p>
                    <p>📞 +919876543210</p>

                    <h5>Email</h5>
                    <p>✉️ abcd.xyz@gmail.com</p>

                    <h5>Follow us</h5>
                    <p>
                        <i class="bi bi-twitter me-2"></i>
                        <i class="bi bi-facebook me-2"></i>
                        <i class="bi bi-instagram"></i>
                    </p>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE (FORM) -->
        <div class="col-md-6 mb-4">
            <div class="card p-4 shadow-sm">

                <h4 class="mb-3">Send a message</h4>

                <form method="post" action="/Home/Contact">

                    <div class="mb-3">
                        <label>Name</label>
                        <input type="text" name="Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" name="Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Subject</label>
                        <input type="text" name="Subject" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Message</label>
                        <textarea name="Message" class="form-control" rows="5"></textarea>
                    </div>

                    <button type="submit" class="btn btn-success">SEND</button>

                </form>

            </div>
        </div>

    </div>
</div>