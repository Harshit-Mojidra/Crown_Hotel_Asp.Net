@{
    ViewBag.Title = "Facilities";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <!-- TITLE -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">OUR FACILITIES</h2>
        <p class="text-muted">
            We offer spacious rooms, high-speed Wi-Fi, 24/7 customer support, and secure parking for your peace of mind.
            Experience comfort and convenience with our modern, well-equipped facilities designed for a relaxing stay.
            Enjoy premium amenities including air conditioning, room service, and hygienic housekeeping.
        </p>
    </div>

    <!-- FACILITIES GRID -->
    <div class="row">

        <!-- WIFI -->
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm h-100 text-center">
                <i class="bi bi-wifi fs-1 mb-3"></i>
                <h5>Wifi</h5>
                <p>Reliable high-speed wireless internet available throughout the room.</p>
            </div>
        </div>

        <!-- AC -->
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm h-100 text-center">
                <i class="bi bi-snow fs-1 mb-3"></i>
                <h5>Air Conditioner</h5>
                <p>Advanced cooling system providing comfortable temperature.</p>
            </div>
        </div>

        <!-- TV -->
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm h-100 text-center">
                <i class="bi bi-tv fs-1 mb-3"></i>
                <h5>Television</h5>
                <p>Modern LED TV with entertainment options for relaxation.</p>
            </div>
        </div>

        <!-- GEYSER -->
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm h-100 text-center">
                <i class="bi bi-droplet fs-1 mb-3"></i>
                <h5>Geyser</h5>
                <p>Instant hot water supply ensuring comfortable showers.</p>
            </div>
        </div>

        <!-- SPA -->
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm h-100 text-center">
                <i class="bi bi-flower1 fs-1 mb-3"></i>
                <h5>Spa</h5>
                <p>Relaxing in-room spa service offering rejuvenation.</p>
            </div>
        </div>

        <!-- HEATER -->
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm h-100 text-center">
                <i class="bi bi-thermometer-half fs-1 mb-3"></i>
                <h5>Room Heater</h5>
                <p>Efficient heating system to keep the room warm.</p>
            </div>
        </div>

    </div>
</div>