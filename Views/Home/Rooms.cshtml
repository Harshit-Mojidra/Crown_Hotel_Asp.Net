@model List<hrbs_project.Models.Room>

@{
    ViewBag.Title = "Rooms";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        overflow-x: hidden;
    }

    .room-img {
        height: 250px;
        width: 100%;
        object-fit: cover;
    }
</style>

<div class="container mt-5">
    <h2 class="text-center mb-4">OUR ROOMS</h2>

    <div class="row">

        <!-- ================= LEFT FILTER ================= -->
        <div class="col-md-3">
            <form method="get" asp-action="Rooms" asp-controller="Home">
                
                <div class="card p-3 shadow-sm">
                    <h5>Filters</h5>

                    <!-- CHECK-IN / CHECK-OUT -->
                    <h6 class="mt-3">Check Availability</h6>

                    <input type="date" name="checkin"
                           value="@Context.Request.Query["checkin"]"
                           class="form-control mb-2"
                           onchange="this.form.submit();" />

                    <input type="date" name="checkout"
                           value="@Context.Request.Query["checkout"]"
                           class="form-control mb-3"
                           onchange="this.form.submit();" />

                    <!-- FACILITIES -->
                    <h6>Facilities</h6>

                    @{
                        var selectedFacilities = Context.Request.Query["facilities"];
                    }

                    <div>
                        <input type="checkbox" name="facilities" value="wifi"
                               onchange="this.form.submit();"
                               @(selectedFacilities.Contains("wifi") ? "checked" : "") /> Wifi
                    </div>

                    <div>
                        <input type="checkbox" name="facilities" value="ac"
                               onchange="this.form.submit();"
                               @(selectedFacilities.Contains("ac") ? "checked" : "") /> AC
                    </div>

                    <div>
                        <input type="checkbox" name="facilities" value="tv"
                               onchange="this.form.submit();"
                               @(selectedFacilities.Contains("tv") ? "checked" : "") /> TV
                    </div>

                    <div>
                        <input type="checkbox" name="facilities" value="geyser"
                               onchange="this.form.submit();"
                               @(selectedFacilities.Contains("geyser") ? "checked" : "") /> Geyser
                    </div>

                    <div>
                        <input type="checkbox" name="facilities" value="spa"
                               onchange="this.form.submit();"
                               @(selectedFacilities.Contains("spa") ? "checked" : "") /> Spa
                    </div>

                    <!-- GUESTS -->
                    <h6 class="mt-3">Guests</h6>

                    <input type="number" name="adults"
                           value="@Context.Request.Query["adults"]"
                           class="form-control mb-2"
                           placeholder="Adults"
                           onchange="this.form.submit();" />

                    <input type="number" name="children"
                           value="@Context.Request.Query["children"]"
                           class="form-control"
                           placeholder="Children"
                           onchange="this.form.submit();" />
                </div>

            </form>
        </div>

        <!-- ================= RIGHT ROOMS LIST ================= -->
        <div class="col-md-9">

            @if (Model.Count == 0)
            {
                <div class="alert alert-danger">
                    No rooms found based on filter
                </div>
            }

            @foreach (var item in Model)
            {
                <div class="card mb-4 shadow-sm">
                    <div class="row g-0">

                        <!-- IMAGE -->
                        <div class="col-md-5">
                            <img src="/images/rooms/@item.Image"
                                 class="room-img rounded-start" />
                        </div>

                        <!-- DETAILS -->
                        <div class="col-md-7">
                            <div class="card-body">

                                <div class="d-flex justify-content-between">
                                    <h5>@item.Name</h5>
                                    <h6>₹@item.Price per night</h6>
                                </div>

                                <p><strong>Features:</strong> @item.Features</p>
                                <p><strong>Facilities:</strong> @item.Facilities</p>
                                <p><strong>Guests:</strong> @item.Adult Adults, @item.Children Children</p>

                                <div class="mt-3">

                                    <!-- ✅ LOGIN CHECK FIX -->
                                    @if (Context.Session.GetInt32("UserId") == null)
                                    {
                                        <button class="btn btn-success"
                                                onclick="setReturnUrl('/Home/ConfirmBooking?id=@item.Id&checkin=@DateTime.Now.ToString("yyyy-MM-dd")&checkout=@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")')"
                                                data-bs-toggle="modal"
                                                data-bs-target="#loginModal">
                                            Book Now
                                        </button>
                                    }
                                    else
                                    {
                                        <a href="/Home/ConfirmBooking?id=@item.Id&checkin=@DateTime.Now.ToString("yyyy-MM-dd")&checkout=@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")"
                                           class="btn btn-success">
                                            Book Now
                                        </a>
                                    }

                                    <button class="btn btn-outline-secondary">
                                        More details
                                    </button>

                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

    </div>
</div>

<!-- ✅ SCRIPT FOR RETURN URL -->
<script>
    function setReturnUrl(url) {
        fetch('/Home/SetReturnUrl?url=' + url);
    }
</script>