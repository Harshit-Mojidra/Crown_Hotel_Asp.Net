<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .top-navbar {
            background: #0f172a;
            padding: 12px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #1e293b;
        }

        .brand-title {
            color: white;
            font-family: 'Cursive', sans-serif;
            margin: 0;
            font-size: 1.5rem;
            font-weight: bold;
        }

        .nav-buttons-group {
            display: flex;
            gap: 10px;
        }

        .main {
            display: flex;
        }

        .sidebar {
            width: 250px;
            background: #0f172a;
            color: white;
            min-height: 100vh;
            padding: 20px;
        }

            .sidebar h4 {
                margin-bottom: 20px;
                font-size: 1.1rem;
                letter-spacing: 1px;
                color: #94a3b8;
            }

            .sidebar a {
                display: block;
                color: #cbd5e1;
                text-decoration: none;
                padding: 10px;
                border-radius: 6px;
                margin-bottom: 5px;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #1e293b;
                    color: white;
                }

        .active-link {
            background: #2563eb;
            color: white !important;
        }

        .submenu {
            display: none;
            margin-left: 10px;
        }

            .submenu a {
                font-size: 14px;
            }

        .content {
            flex-grow: 1;
            padding: 20px;
            background: #f8fafc;
        }
    </style>
</head>

<body>
    <div class="top-navbar">
        <h2 class="brand-title">Crown Hotel</h2>

        <div class="nav-buttons-group">
            <a href="/Admin/Dashboard" class="btn btn-success btn-sm px-3">Dashboard</a>
            <a href="/Account/Logout" class="btn btn-danger btn-sm px-3">Logout</a>
        </div>
    </div>

    <div class="main">

        <div class="sidebar">

            <h4>ADMIN PANEL</h4>

            <a asp-controller="Admin" asp-action="Dashboard" class="active-link">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a href="javascript:void(0)" onclick="toggleMenu()">
                <i class="bi bi-calendar-check"></i> Bookings <i class="bi bi-chevron-down float-end"></i>
            </a>

            <div class="submenu" id="bookingMenu">
                <a asp-controller="Admin" asp-action="NewBookings">New Bookings</a>
                <a asp-controller="Admin" asp-action="RefundBookings">Refund Bookings</a>
                <a asp-controller="Admin" asp-action="BookingRecords">Booking Records</a>
            </div>

            <a asp-controller="Admin" asp-action="Users">
                <i class="bi bi-people"></i> Users
            </a>

            <a asp-controller="RatingReview" asp-action="Reviews">
                <i class="bi bi-star"></i> Ratings & Reviews
            </a>

            <a asp-controller="Admin" asp-action="Rooms">
                <i class="bi bi-door-open"></i> Rooms
            </a>

            <a asp-controller="Admin" asp-action="FeaturesFacilities">
                <i class="bi bi-list-check"></i> Features & Facilities
            </a>

            <a asp-controller="Admin" asp-action="Settings">
                <i class="bi bi-gear"></i> Settings
            </a>

        </div>

        <div class="content">
            @RenderBody()
        </div>

    </div>

    <script>
        function toggleMenu() {
            var menu = document.getElementById("bookingMenu");
            if (menu.style.display === "block") {
                menu.style.display = "none";
            } else {
                menu.style.display = "block";
            }
        }
    </script>

</body>
</html>