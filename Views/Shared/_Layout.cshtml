<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Crown Hotel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
                .navbar-brand {
                        font-size: 28px;
                        font-weight: bold;
                        font-family: 'Georgia', serif;

        }

                .nav-link {
                        font-size: 16px;
                        margin-right: 15px;

        }

                .hero-section {
                        position: relative;

        }

                    .hero-section img {
                            width: 100%;
                            height: 420px;
                            object-fit: cover;

        }

                .booking-box {
                        position: absolute;
                        bottom: -60px;
                        left: 50%;
                        transform: translateX(-50%);
                        width: 85%;
                        background: #fff;
                        padding: 25px;
                        border-radius: 10px;
                        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
                        z-index: 10;

        }

                .after-hero {
                        margin-top: 100px;

        }
        /* --- FOOTER STYLING --- */
        .footer-section {
            background-color: white;
            padding: 80px 0 0 0; /* Extra top padding for that spacious look */
            margin-top: 100px;
        }

            .footer-section h4 {
                font-family: 'Playfair Display', serif; /* Use a serif font for the logo style */
                font-weight: 800;
                font-style: italic;
                margin-bottom: 20px;
            }

            .footer-section h5 {
                font-weight: 700;
                margin-bottom: 25px;
            }

            .footer-section p {
                font-size: 15px;
                line-height: 1.6;
                color: #444;
            }

            .footer-section a {
                font-size: 15px;
                color: #222 !important;
                margin-bottom: 12px !important;
                transition: 0.3s;
            }

                .footer-section a:hover {
                    color: #555 !important;
                }

            .footer-section i {
                font-size: 18px;
                vertical-align: middle;
            }

        /* The dark bottom bar */
        .copyright-bar {
            background-color: #212529; /* Matches the dark gray/black bar in image */
            color: white;
            padding: 15px 0;
            margin-top: 50px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }


    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-light shadow-sm">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Crown Hotel
            </a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Rooms">Rooms</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Facilities">Facilities</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                </ul>

                <div class="d-flex align-items-center">

                    @if (Context.Session.GetString("User") == null)
                    {
                        <button class="btn btn-outline-dark me-2" data-bs-toggle="modal" data-bs-target="#loginModal">
                            Login
                        </button>

                        <button class="btn btn-outline-dark me-3" data-bs-toggle="modal" data-bs-target="#registerModal">
                            Register
                        </button>
                    }
                    else
                    {
                        <span class="me-3">@Context.Session.GetString("User")</span>

                        <a href="/Account/Logout" class="btn btn-danger me-3">
                            Logout
                        </a>
                    }

                    @if (Context.Session.GetString("Admin") == null)
                    {
                        <a href="/Admin/Login" class="btn btn-dark">Admin</a>
                    }
                    else
                    {
                        <a href="/Admin/Dashboard" class="btn btn-success me-2">Dashboard</a>
                        <a href="/Admin/Logout" class="btn btn-danger">Logout</a>
                    }

                </div>
            </div>
        </div>
    </nav>

    <!-- ALERT -->
    @if (TempData["Error"] != null)
    {
        <script>alert("@TempData["Error"]");</script>
    }

    @if (TempData["Success"] != null)
    {
        <script>alert("@TempData["Success"]");</script>
    }

    <!-- BODY -->
    @RenderBody()

    <!-- ================= LOGIN MODAL ================= -->
    <div class="modal fade" id="loginModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-3">

                <div class="d-flex justify-content-between">
                    <h5>User Login</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form method="post" action="/Account/Login">
                    <input name="email" class="form-control mt-3" placeholder="Email" required />
                    <input name="password" type="password" class="form-control mt-2" placeholder="Password" required />

                    <div class="d-flex justify-content-between mt-3">
                        <button class="btn btn-dark">Login</button>

                        <!-- ✅ FORGOT PASSWORD LINK -->
                        <a href="#" data-bs-toggle="modal" data-bs-target="#forgotModal" data-bs-dismiss="modal">
                            Forgot Password?
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <!-- ================= REGISTER MODAL ================= -->
    <div class="modal fade" id="registerModal">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content p-4">

                <h4>Register</h4>

                <form method="post" action="/Account/Register" enctype="multipart/form-data">

                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <input name="Name" class="form-control" placeholder="Name" required />
                        </div>

                        <div class="col-md-6 mb-2">
                            <input name="Email" class="form-control" placeholder="Email" required />
                        </div>

                        <div class="col-md-6 mb-2">
                            <input name="Phone" class="form-control" placeholder="Phone" />
                        </div>

                        <div class="col-md-6 mb-2">
                            <input type="file" name="ImageFile" class="form-control" />
                        </div>

                        <div class="col-12 mb-2">
                            <textarea name="Address" class="form-control" placeholder="Address"></textarea>
                        </div>

                        <div class="col-md-6 mb-2">
                            <input name="Password" type="password" class="form-control" placeholder="Password" required />
                        </div>

                        <div class="col-md-6 mb-2">
                            <input name="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" required />
                        </div>
                    </div>

                    <button class="btn btn-dark w-100 mt-2">Register</button>
                </form>

            </div>
        </div>
    </div>

    <!-- ================= FORGOT PASSWORD MODAL ================= -->
    <div class="modal fade" id="forgotModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-3">

                <div class="d-flex justify-content-between">
                    <h5>Forgot Password</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <p class="mt-2 text-muted">
                    Enter your email to receive reset link
                </p>

                <form method="post" action="/Account/ForgotPassword">
                    <input type="email" name="email" class="form-control mt-2" placeholder="Enter Email" required />

                    <div class="text-end mt-3">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-dark">Send Link</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <footer class="footer-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h4 class="fw-bold italic">CROWN PALACE</h4>
                    <p class="text-muted">High-quality description of your hotel goes here.</p>
                </div>
                <div class="col-lg-4 mb-4 ps-lg-5">
                    <h5 class="fw-bold mb-3">Links</h5>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2">Home</a>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2">Rooms</a>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2">Facilities</a>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2">About Us</a>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2">Contact us</a>
                </div>
                <div class="col-lg-4 mb-4">
                    <h5 class="fw-bold mb-3">Follow us</h5>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2"><i class="bi bi-twitter me-2"></i>Twitter</a>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2"><i class="bi bi-facebook me-2"></i>Facebook</a>
                    <a href="#" class="text-decoration-none text-dark d-block mb-2"><i class="bi bi-instagram me-2"></i>Instagram</a>
                </div>
            </div>
        </div>
        <div class="copyright-bar text-center">
            Designed and Developed by V8 Company..!
        </div>
    </footer>
</body>
</html>